{
  "compilerOptions": {
    "target": "ES2022",                          /* Modern ECMAScript version */
    "module": "commonjs",                        /* Standard module system for Node.js */
    "rootDir": "./src",                          /* Location of your TypeScript source code */
    "outDir": "./dist",                          /* Destination for compiled JavaScript code */
    "strict": true,                              /* Enables strict type-checking options */
    "esModuleInterop": true,                     /* Emits additional JavaScript for easy imports */
    "skipLibCheck": true,                        /* Skip type checking of declaration files */
    "forceConsistentCasingInFileNames": true     /* Ensure case sensitivity matches across systems */
  },
  "include": ["src/**/*"]                        /* Compile only files within the src directory */
}
